{
  "name": "TokenGhost",
  "version": "1.0.0",
  "description": "Zero-latency token auditing proxy and MCP server to track, analyze, and optimize LLM token consumption across Antigravity, Cursor, Copilot, and more.",
  "main": "index.js",
  "scripts": {
    "start": "tsx --no-warnings src/index.ts",
    "mcp": "tsx --no-warnings src/index.ts --mcp",
    "install:mcp": "tsx scripts/install-mcp.ts",
    "build": "tsc"
  },
  "keywords": [
    "mcp-server",
    "token-tracker",
    "llm-auditing",
    "ai-cost-optimization",
    "openai",
    "anthropic",
    "gemini",
    "antigravity-plugin",
    "cursor-rules"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.10.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "http-proxy": "^1.18.1"
  },
  "devDependencies": {
    "@types/http-proxy": "^1.17.17",
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
